# Mobile app talks to the standalone Fulbito API service, not directly to PocketBase.
# Hosted API example: https://fulbitoprode.onrender.com
# Custom domain (recommended): https://api.fulbitoprode.com
# iOS simulator: localhost works.
# Android emulator: use http://10.0.2.2:3000
# Physical device: use your machine LAN IP, e.g. http://192.168.1.50:3000
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
# Keep false for real auth/data. Set true only for local UI-only testing.
EXPO_PUBLIC_ENABLE_MOCK_FALLBACK=false

# Google OAuth client IDs (create in Google Cloud Console)
# Expo Go: OAuth Client Type "Web application"
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
# Native iOS client ID
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
# Native Android client ID
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
# Web client ID (also used for backend audience validation)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
