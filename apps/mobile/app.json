{
  "expo": {
    "name": "Fulbito Prode",
    "slug": "fulbito-prode-monorepo",
    "scheme": "fulbito",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/branding/app-icon-1024.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.fulbito.prode",
      "icon": "./assets/branding/app-icon-1024.png"
    },
    "android": {
      "package": "com.fulbito.prode",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/branding/adaptive-foreground-1024.png",
        "backgroundColor": "#0A0A0A"
      },
      "notification": {
        "icon": "./assets/branding/notification-icon-96.png",
        "color": "#0A0A0A"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/branding/app-icon-1024.png"
    },
    "extra": {
      "eas": {
        "projectId": "b06c2f2d-359f-4070-ba6a-1465e90ce963"
      }
    },
    "owner": "fcontre"
  }
}
