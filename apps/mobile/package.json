{
  "name": "@fulbito/mobile",
  "private": true,
  "version": "0.1.0",
  "main": "index.js",
  "scripts": {
    "dev": "node ./scripts/check-node-version.mjs && expo start",
    "android": "node ./scripts/check-node-version.mjs && expo run:android",
    "android:smoke": "node ./scripts/check-node-version.mjs && expo start --android --port 8083",
    "ios": "node ./scripts/check-node-version.mjs && expo run:ios",
    "ios:smoke": "node ./scripts/check-node-version.mjs && expo start --ios --port 8082",
    "web": "node ./scripts/check-node-version.mjs && expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "node ./scripts/run-mobile-tests.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.0",
    "@fulbito/api-contracts": "workspace:*",
    "@fulbito/design-tokens": "workspace:*",
    "@fulbito/domain": "workspace:*",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.1.1",
    "@react-navigation/native": "^7.0.14",
    "@react-navigation/native-stack": "^7.1.1",
    "@tanstack/react-query": "^5.64.2",
    "expo": "~54.0.33",
    "expo-auth-session": "^7.0.10",
    "expo-crypto": "^15.0.8",
    "expo-device": "^55.0.9",
    "expo-notifications": "^55.0.12",
    "expo-status-bar": "~3.0.8",
    "expo-web-browser": "^15.0.10",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.3",
    "react-native-worklets": "~0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "^19.1.17",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.13",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  }
}
