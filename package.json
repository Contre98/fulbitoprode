{
  "name": "fulbito-prode-monorepo",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:api": "pnpm --filter @fulbito/api dev",
    "dev:mobile": "pnpm --filter @fulbito/mobile dev",
    "build": "turbo run build",
    "build:api": "pnpm --filter @fulbito/api build",
    "lint": "turbo run lint",
    "lint:api": "pnpm --filter @fulbito/api lint",
    "typecheck": "turbo run typecheck",
    "typecheck:api": "pnpm --filter @fulbito/api typecheck",
    "test": "turbo run test",
    "test:run": "pnpm --filter @fulbito/api test"
  },
  "devDependencies": {
    "turbo": "^2.4.4"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "^19.0.2",
      "@types/react-dom": "^19.0.2"
    }
  }
}
